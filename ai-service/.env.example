# === Groq LLM (REQUIRED) ===
GROQ_API_KEY=gsk_your_groq_api_key_here
GROQ_MODEL_PRIMARY=llama-3.3-70b-versatile
GROQ_MODEL_FAST=llama-3.1-8b-instant

# === NestJS Backend ===
NESTJS_BASE_URL=http://localhost:3000
NESTJS_SERVICE_API_KEY=dev-key

# === Qdrant Vector DB ===
QDRANT_URL=http://localhost:6333

# === Redis ===
REDIS_URL=redis://localhost:6379

# === LangSmith (optional — enables per-node tracing) ===
# LANGSMITH_API_KEY=ls__your_key_here
# LANGSMITH_PROJECT=mongez-ai

# === Service Auth (must match AI_SERVICE_API_KEY in NestJS .env) ===
SERVICE_API_KEY=dev-key

# === Debug ===
DEBUG=false
