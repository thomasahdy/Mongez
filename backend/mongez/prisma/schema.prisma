generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// ENUMS
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

enum UserStatus {
  ACTIVE
  INACTIVE
  INVITED
  SUSPENDED
}

enum TaskStatus {
  BACKLOG
  TODO
  IN_PROGRESS
  IN_REVIEW
  BLOCKED
  DONE
  CANCELLED
}

enum Priority {
  URGENT
  HIGH
  MEDIUM
  LOW
  NONE
}

enum BoardType {
  KANBAN
  LIST
  TABLE
  TIMELINE
  CALENDAR
  WHITEBOARD
}

enum NotificationType {
  TASK_ASSIGNED
  TASK_DUE
  TASK_UPDATED
  COMMENT_MENTION
  APPROVAL_REQUESTED
  APPROVAL_RESOLVED
  FILE_UPLOADED
  AI_INSIGHT
  SYSTEM
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  WITHDRAWN
}

enum NotificationPriority {
  LOW
  NORMAL
  HIGH
  CRITICAL
}

enum NotificationStatus {
  PENDING
  QUEUED
  AGGREGATED
  DELIVERED
  READ
  FAILED
  DISMISSED
  EXPIRED
}

enum NotificationChannelType {
  IN_APP
  PUSH
  EMAIL
}

enum SubscriptionTier {
  FREE
  PRO
  ENTERPRISE
}

enum DependencyType {
  BLOCKS
  DUPLICATES
  RELATES_TO
  FOLLOWS
  PRECEDES
  PART_OF
  REQUIRES
}


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// IDENTITY & ACCESS
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

model User {
  id             String     @id @default(cuid())
  email          String     @unique
  passwordHash   String?
  provider       String?
  providerId     String?    @unique
  name           String
  avatarUrl      String?
  language       String     @default("en")
  status         UserStatus @default(ACTIVE)
  isVerified     Boolean    @default(false)
  failedAttempts Int        @default(0)
  lockedUntil    DateTime?
  lastLoginAt    DateTime?
  emailVerificationToken String?   @unique
  emailVerifiedAt        DateTime?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  // Relations
  sessions       UserSession[]
  passwordResets PasswordReset[]
  emailVerifications EmailVerification[]
  memberships    Membership[]
  assignedTasks  TaskAssignment[]
  comments       Comment[]        @relation("CommentAuthor")
  notifications  Notification[]
  notificationPreference NotificationPreference?
  deviceSessions DeviceSession[]
  timeLogs       TimeLog[]
  auditLogs      AuditLog[]
  logs           UserLog[]
  sentApprovals  Approval[]       @relation("ApprovalRequester")
  reviewedApprovals Approval[]    @relation("ApprovalReviewer")
  uploadedFiles  FileVersion[]
  activities     Activity[]
  subscriptions  Subscription[]
  watchers       Watcher[]
  aiRequests        AIRequest[]
  reviewedAIActions AIProposedAction[] @relation("AIActionReviewer")

  @@index([email])
  @@index([status])
  @@map("users")
}

model UserLog {
  id         String   @id @default(cuid())
  userId     String
  action     String
  ipAddress  String?
  userAgent  String?
  metadata   Json?
  createdAt  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("user_logs")
}

model UserSession {
  id           String   @id @default(cuid())
  userId       String
  refreshToken String   @unique
  ip           String?
  userAgent    String?
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([refreshToken])
  @@index([expiresAt])
  @@map("user_sessions")
}

model PasswordReset {
  id         String   @id @default(cuid())
  userId     String
  token      String   @unique
  expiresAt  DateTime
  attempts   Int      @default(0)
  used       Boolean  @default(false)
  createdAt  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
  @@map("password_resets")
}

model EmailVerification {
  id         String   @id @default(cuid())
  userId     String
  token      String   @unique
  expiresAt  DateTime
  used       Boolean  @default(false)
  createdAt  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
  @@map("email_verifications")
}

model Role {
  id          String       @id @default(cuid())
  name        String       @unique // "OWNER" | "ADMIN" | "HEAD" | "MEMBER" | "VIEWER"
  description String?

  memberships Membership[]
  permissions RolePermission[]

  @@map("roles")
}

model Permission {
  id          String           @id @default(cuid())
  action      String           // "create" | "read" | "update" | "delete" | "approve"
  resource    String           // "task" | "board" | "space" | "report" etc.
  description String?

  roles       RolePermission[]

  @@unique([action, resource])
  @@map("permissions")
}

model RolePermission {
  roleId       String
  permissionId String

  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// WORKSPACE HIERARCHY
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

model Space {
  id                 String            @id @default(cuid())
  name               String
  description        String?
  icon               String?           // emoji or fa icon class
  color              String?           // hex color
  prefix             String            @default("PRJ") // used in task identifiers e.g. PRJ-001
  isPublic           Boolean           @default(false)
  subscriptionPlanId String?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  subscriptionPlan   SubscriptionPlan? @relation(fields: [subscriptionPlanId], references: [id])
  departments        Department[]
  memberships        Membership[]
  invitations        Invitation[]
  counter            SpaceCounter?

  @@index([createdAt])
  @@map("spaces")
}

model Department {
  id          String   @id @default(cuid())
  name        String
  description String?
  spaceId     String
  color       String?
  createdAt   DateTime @default(now())

  space     Space    @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  boards    Board[]
  memberships Membership[]

  @@index([spaceId])
  @@map("departments")
}

model Membership {
  id           String    @id @default(cuid())
  userId       String
  spaceId      String?   // set when member of a Space
  departmentId String?   // set when member of a Department
  roleId       String
  invitedAt    DateTime  @default(now())
  acceptedAt   DateTime?

  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  role         Role      @relation(fields: [roleId], references: [id])
  space        Space?    @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  department   Department? @relation(fields: [departmentId], references: [id], onDelete: Cascade)

  @@unique([userId, spaceId])
  @@unique([userId, departmentId])
  @@index([userId])
  @@index([spaceId])
  @@index([departmentId])
  @@index([roleId])
  @@map("memberships")
}

model SubscriptionPlan {
  id          String   @id @default(cuid())
  name        String   @unique // "FREE" | "PRO" | "ENTERPRISE"
  maxSpaces   Int
  maxUsers    Int
  maxBoards   Int
  aiEnabled   Boolean  @default(false)
  price       Float

  spaces      Space[]

  @@map("subscription_plans")
}

model SpaceCounter {
  spaceId String @id
  seq     Int    @default(0)

  space   Space  @relation(fields: [spaceId], references: [id], onDelete: Cascade)

  @@map("space_counters")
}

model Invitation {
  id        String   @id @default(cuid())
  email     String
  spaceId   String
  role      String   @default("MEMBER")
  token     String   @unique @default(cuid())
  expiresAt DateTime
  accepted  Boolean  @default(false)
  createdAt DateTime @default(now())

  space     Space    @relation(fields: [spaceId], references: [id], onDelete: Cascade)

  @@index([email, spaceId])
  @@index([token])
  @@map("invitations")
}

model Subscription {
  id           String           @id @default(cuid())
  userId       String
  tier         SubscriptionTier @default(FREE)
  startsAt     DateTime         @default(now())
  expiresAt    DateTime?
  isAutoRenew  Boolean          @default(false)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tier])
  @@map("subscriptions")
}

// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// BOARDS
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

model Board {
  id           String      @id @default(cuid())
  name         String
  description  String?
  departmentId String
  type         BoardType   @default(KANBAN)
  position     Int         @default(0)
  color        String?
  icon         String?
  isArchived   Boolean     @default(false)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  department   Department  @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  columns      BoardColumn[]
  tasks        Task[]
  views        View[]

  @@index([departmentId])
  @@index([isArchived])
  @@index([createdAt])
  @@map("boards")
}

model BoardColumn {
  id        String   @id @default(cuid())
  boardId   String
  name      String
  position  Int
  color     String?
  wipLimit  Int?

  board     Board    @relation(fields: [boardId], references: [id], onDelete: Cascade)
  tasks     Task[]

  @@index([boardId])
  @@map("board_columns")
}

model View {
  id          String    @id @default(cuid())
  boardId     String
  name        String
  type        BoardType
  filters     Json?     // serialized filter config
  groupBy     String?
  sortBy      String?
  sortOrder   String?   // "asc" | "desc"
  isDefault   Boolean   @default(false)
  createdById String
  createdAt   DateTime  @default(now())

  board       Board     @relation(fields: [boardId], references: [id], onDelete: Cascade)

  @@index([boardId])
  @@index([createdById])
  @@map("views")
}

// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// TASKS
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

model Task {
  id              String       @id @default(cuid())
  identifier      String       @unique // "EDU-042" auto-generated
  title           String
  description     String?      // rich markdown
  boardId         String
  columnId        String?
  status          TaskStatus   @default(TODO)
  priority        Priority     @default(MEDIUM)
  type            String?      // "Task" | "Bug" | "Feature" | "Milestone"
  position        Int          @default(0)
  estimatedHours  Float?
  percentDone     Int          @default(0)
  dueDate         DateTime?
  startDate       DateTime?
  parentId        String?      // for subtasks (self-relation)
  tags            String[]
  searchVector    Unsupported("tsvector")?
  isArchived      Boolean      @default(false)
  createdById     String
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  board           Board        @relation(fields: [boardId], references: [id], onDelete: Cascade)
  column          BoardColumn? @relation(fields: [columnId], references: [id], onDelete: SetNull)
  parent          Task?        @relation("Subtasks", fields: [parentId], references: [id], onDelete: SetNull)
  subtasks        Task[]       @relation("Subtasks")
  assignments     TaskAssignment[]
  dependencies    TaskDependency[] @relation("DependencyOf")
  dependents      TaskDependency[] @relation("DependentOn")
  comments        Comment[]
  attachments     Attachment[]
  approvals       Approval[]
  timeLogs        TimeLog[]
  watchers        Watcher[]
  journalEntries  TaskJournal[]
  activities      Activity[]

  @@index([boardId])
  @@index([columnId])
  @@index([parentId])
  @@index([status])
  @@index([priority])
  @@index([dueDate])
  @@index([isArchived])
  @@index([searchVector], type: Gin)
  @@index([identifier])
  @@index([createdById])
  @@index([createdAt])
  @@map("tasks")
}

model TaskAssignment {
  taskId     String
  userId     String
  assignedAt DateTime @default(now())

  task       Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([taskId, userId])
  @@index([userId])
  @@map("task_assignments")
}

model TaskDependency {
  id             String         @id @default(cuid())
  taskId         String         // the dependent task
  dependsOnId    String         // the prerequisite task
  type           DependencyType @default(BLOCKS)

  task           Task           @relation("DependencyOf", fields: [taskId], references: [id], onDelete: Cascade)
  dependsOn      Task           @relation("DependentOn", fields: [dependsOnId], references: [id], onDelete: Cascade)

  @@unique([taskId, dependsOnId])
  @@index([dependsOnId])
  @@map("task_dependencies")
}

model TimeLog {
  id        String   @id @default(cuid())
  taskId    String
  userId    String
  hours     Float
  loggedAt  DateTime @default(now())
  note      String?

  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([userId])
  @@index([loggedAt])
  @@map("time_logs")
}

model Watcher {
  taskId String
  userId String

  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([taskId, userId])
  @@map("watchers")
}

// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// COLLABORATION
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

model Comment {
  id        String    @id @default(cuid())
  taskId    String
  authorId  String
  content   String    // markdown with @mention support
  isEdited  Boolean   @default(false)
  deletedAt DateTime?              // soft delete
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  task      Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  author    User      @relation("CommentAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  mentions  Mention[]
  reactions EmojiReaction[]

  @@index([taskId])
  @@index([authorId])
  @@index([createdAt])
  @@map("comments")
}

model Mention {
  commentId   String
  mentionedId String // userId
  isRead      Boolean  @default(false)

  comment     Comment  @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@id([commentId, mentionedId])
  @@index([mentionedId])
  @@index([isRead])
  @@map("mentions")
}

model EmojiReaction {
  id        String   @id @default(cuid())
  commentId String
  userId    String
  emoji     String

  comment   Comment  @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@unique([commentId, userId, emoji])
  @@index([commentId])
  @@map("emoji_reactions")
}

// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// FILES & VERSIONS
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

model Attachment {
  id               String       @id @default(cuid())
  taskId           String
  fileName         String
  mimeType         String
  currentVersionId String?
  uploadedById     String
  createdAt        DateTime     @default(now())

  task             Task         @relation(fields: [taskId], references: [id], onDelete: Cascade)
  versions         FileVersion[]

  @@index([taskId])
  @@map("attachments")
}

model FileVersion {
  id           String     @id @default(cuid())
  attachmentId String
  s3Key        String
  versionNum   Int
  sizeBytes    Int
  uploadedById String
  uploadedAt   DateTime   @default(now())

  attachment   Attachment @relation(fields: [attachmentId], references: [id], onDelete: Cascade)
  uploader     User       @relation(fields: [uploadedById], references: [id], onDelete: Cascade)

  @@index([attachmentId])
  @@index([uploadedById])
  @@map("file_versions")
}

// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// APPROVALS & WORKFLOWS
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

model Approval {
  id            String         @id @default(cuid())
  taskId        String
  requestedById String
  reviewerId    String?
  status        ApprovalStatus @default(PENDING)
  comment       String?
  requestedAt   DateTime       @default(now())
  resolvedAt    DateTime?

  task          Task           @relation(fields: [taskId], references: [id], onDelete: Cascade)
  requester     User           @relation("ApprovalRequester", fields: [requestedById], references: [id])
  reviewer      User?          @relation("ApprovalReviewer", fields: [reviewerId], references: [id])

  @@index([taskId])
  @@index([requestedById])
  @@index([reviewerId])
  @@index([status])
  @@index([requestedAt])
  @@map("approvals")
}

// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// NOTIFICATIONS & AUDIT
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

model OutboxEvent {
  id            String   @id @default(cuid())
  aggregateType String   
  aggregateId   String
  eventType     String   
  payload       Json     
  processedAt   DateTime?
  createdAt     DateTime @default(now())

  @@index([processedAt, createdAt])
  @@map("outbox_events")
}

model Notification {
  id                String    @id @default(cuid())
  userId            String
  spaceId           String    
  type              String    
  priority          NotificationPriority  @default(NORMAL)
  channel           NotificationChannelType
  title             String
  body              String
  entityType        String?   
  entityId          String?
  status            NotificationStatus @default(PENDING)
  aggregatedGroupId String?   
  deliveredAt       DateTime?
  readAt            DateTime?
  failedAt          DateTime?
  metadata          Json?     
  templateVersion   Int       @default(1)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, spaceId, status])
  @@index([aggregatedGroupId])
  @@map("notifications")
}

model NotificationPreference {
  id           String   @id @default(cuid())
  userId       String   @unique
  preferences  Json     
  quietHours   Json?    
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notification_preferences")
}

model DeviceSession {
  id           String   @id @default(cuid())
  userId       String
  deviceType   String   
  pushToken    String?  
  lastSeen     DateTime @default(now())
  revokedAt    DateTime?
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, revokedAt])
  @@map("device_sessions")
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String
  action     String   // "task.created" | "task.status_changed" | "member.invited" ...
  entityType String
  entityId   String
  diff       Json?    // before/after JSON
  ipAddress  String?
  timestamp  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([action])
  @@index([entityType, entityId])
  @@index([timestamp])
  @@map("audit_logs")
}

model TaskJournal {
  id        String   @id @default(cuid())
  taskId    String
  userId    String
  changes   Json     // { field: "status", from: "TODO", to: "IN_PROGRESS" }
  note      String?
  createdAt DateTime @default(now())

  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([userId])
  @@index([createdAt])
  @@map("task_journal")
}

// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// ACTIVITY LOG
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

model Activity {
  id        String   @id @default(cuid())
  userId    String
  taskId    String?
  type      String
  data      Json?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  task      Task?    @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([taskId])
  @@index([type])
  @@index([createdAt])
  @@map("activities")
}

// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// AI SYSTEM
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

model AIRequest {
  id              String   @id @default(cuid())
  traceId         String   @unique
  userId          String
  spaceId         String
  intent          String                  // 'risk' | 'chat' | 'report' | 'action'
  rawInput        String
  rewrittenQuery  String?
  finalResponse   String?
  modelUsed       String?                 // 'llama-3.3-70b' | 'gemma2-9b' etc. (via Groq)
  tokensIn        Int?
  tokensOut       Int?
  latencyMs       Int?
  ttftMs          Int?
  qualityScore    Float?
  userFeedback    Int?                    // 1 = thumbs up, -1 = thumbs down
  feedbackNote    String?
  status          String   @default("pending") // pending | completed | failed
  errorMessage    String?
  createdAt       DateTime @default(now())

  user            User     @relation(fields: [userId], references: [id])
  proposedActions AIProposedAction[]

  @@index([userId])
  @@index([spaceId])
  @@index([intent])
  @@index([traceId])
  @@index([createdAt])
  @@map("ai_requests")
}

model AIProposedAction {
  id              String         @id @default(cuid())
  traceId         String
  spaceId         String
  commandType     String         // 'AssignTask' | 'CreateTask' | 'EscalateTask' | 'UpdateTask' | 'CreateReminder'
  payload         Json
  reason          String
  status          ApprovalStatus @default(PENDING)
  reviewedById    String?
  reviewedAt      DateTime?
  createdAt       DateTime       @default(now())

  aiRequest       AIRequest      @relation(fields: [traceId], references: [traceId])
  reviewer        User?          @relation("AIActionReviewer", fields: [reviewedById], references: [id])

  @@index([traceId])
  @@index([spaceId])
  @@index([status])
  @@map("ai_proposed_actions")
}

model AIEvalResult {
  id              String   @id @default(cuid())
  traceId         String?
  evalType        String   // 'shadow' | 'ci' | 'manual'
  feature         String   // 'risk_detection' | 'chat' | 'report'
  metricName      String   // 'f1' | 'rubric_score' | 'faithfulness'
  metricValue     Float
  details         Json?
  promptVersion   String?
  modelUsed       String?
  createdAt       DateTime @default(now())

  @@index([feature])
  @@index([metricName])
  @@index([createdAt])
  @@map("ai_eval_results")
}