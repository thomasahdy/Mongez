generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// ENUMS
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

enum AttachmentProvider {
  LOCAL
  S3
  GOOGLE_DRIVE
  ONEDRIVE
  DROPBOX
}

enum EmbeddingStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum UserStatus {
  ACTIVE
  INACTIVE
  INVITED
  SUSPENDED
}

enum TaskStatus {
  BACKLOG
  TODO
  IN_PROGRESS
  IN_REVIEW
  BLOCKED
  DONE
  CANCELLED
}

enum Priority {
  URGENT
  HIGH
  MEDIUM
  LOW
  NONE
}

enum BoardType {
  KANBAN
  LIST
  TABLE
  TIMELINE
  CALENDAR
  WHITEBOARD
}

enum NotificationType {
  TASK_ASSIGNED
  TASK_DUE
  TASK_UPDATED
  COMMENT_MENTION
  APPROVAL_REQUESTED
  APPROVAL_RESOLVED
  FILE_UPLOADED
  AI_INSIGHT
  SYSTEM
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  WITHDRAWN
}

enum NotificationPriority {
  LOW
  NORMAL
  HIGH
  CRITICAL
}

enum NotificationStatus {
  PENDING
  QUEUED
  AGGREGATED
  DELIVERED
  READ
  FAILED
  DISMISSED
  EXPIRED
}

enum NotificationChannelType {
  IN_APP
  PUSH
  EMAIL
  WHATSAPP
  TELEGRAM
}

enum SubscriptionTier {
  FREE
  PRO
  ENTERPRISE
}

enum DependencyType {
  BLOCKS
  DUPLICATES
  RELATES_TO
  FOLLOWS
  PRECEDES
  PART_OF
  REQUIRES
}


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// IDENTITY & ACCESS
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

model User {
  id             String     @id @default(cuid())
  email          String     @unique
  passwordHash   String?
  provider       String?
  providerId     String?    @unique
  name           String
  avatarUrl      String?
  language       String     @default("en")
  status         UserStatus @default(ACTIVE)
  isVerified     Boolean    @default(false)
  failedAttempts Int        @default(0)
  lockedUntil    DateTime?
  lastLoginAt    DateTime?
  emailVerificationToken String?   @unique
  emailVerifiedAt        DateTime?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  // Relations
  sessions       UserSession[]
  passwordResets PasswordReset[]
  emailVerifications EmailVerification[]
  memberships    Membership[]
  assignedTasks  TaskAssignment[]
  comments       Comment[]        @relation("CommentAuthor")
  notifications  Notification[]
  notificationPreference NotificationPreference?
  deviceSessions DeviceSession[]
  timeLogs       TimeLog[]
  auditLogs      AuditLog[]
  logs           UserLog[]
  sentApprovals  Approval[]       @relation("ApprovalRequester")
  reviewedApprovals Approval[]    @relation("ApprovalReviewer")
  uploadedFiles  FileVersion[]
  activities     Activity[]
  subscriptions  Subscription[]
  watchers       Watcher[]
  aiRequests        AIRequest[]
  reviewedAIActions AIProposedAction[] @relation("AIActionReviewer")
  workflowInstances WorkflowInstance[] @relation("WorkflowRequester")
  aiConversationTurns AIConversationTurn[]
  executedAIActions AIProposedAction[] @relation("AIActionExecutor")
  preference     UserPreference?
  integrations   Integration[]
  aiMemoryProfile AIMemoryProfile?

  @@index([email])
  @@index([status])
  @@map("users")
}

model UserLog {
  id         String   @id @default(cuid())
  userId     String
  action     String
  ipAddress  String?
  userAgent  String?
  metadata   Json?
  createdAt  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("user_logs")
}

model UserSession {
  id           String   @id @default(cuid())
  userId       String
  refreshToken String   @unique
  ip           String?
  userAgent    String?
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([refreshToken])
  @@index([expiresAt])
  @@map("user_sessions")
}

model PasswordReset {
  id         String   @id @default(cuid())
  userId     String
  token      String   @unique
  expiresAt  DateTime
  attempts   Int      @default(0)
  used       Boolean  @default(false)
  createdAt  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
  @@map("password_resets")
}

model EmailVerification {
  id         String   @id @default(cuid())
  userId     String
  token      String   @unique
  expiresAt  DateTime
  used       Boolean  @default(false)
  createdAt  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
  @@map("email_verifications")
}

model Role {
  id          String       @id @default(cuid())
  name        String       @unique // "OWNER" | "ADMIN" | "HEAD" | "MEMBER" | "VIEWER"
  description String?

  memberships Membership[]
  permissions RolePermission[]

  @@map("roles")
}

model Permission {
  id          String           @id @default(cuid())
  action      String           // "create" | "read" | "update" | "delete" | "approve"
  resource    String           // "task" | "board" | "space" | "report" etc.
  description String?

  roles       RolePermission[]

  @@unique([action, resource])
  @@map("permissions")
}

model RolePermission {
  roleId       String
  permissionId String

  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// WORKSPACE HIERARCHY
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

model Space {
  id                 String            @id @default(cuid())
  name               String
  description        String?
  icon               String?           // emoji or fa icon class
  color              String?           // hex color
  prefix             String            @default("PRJ") // used in task identifiers e.g. PRJ-001
  isPublic           Boolean           @default(false)
  subscriptionPlanId String?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  subscriptionPlan   SubscriptionPlan? @relation(fields: [subscriptionPlanId], references: [id])
  departments        Department[]
  memberships        Membership[]
  invitations        Invitation[]
  counter            SpaceCounter?
  attachments        Attachment[]

  @@index([createdAt])
  @@map("spaces")
}

model Department {
  id          String   @id @default(cuid())
  name        String
  description String?
  spaceId     String
  color       String?
  createdAt   DateTime @default(now())

  space     Space    @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  boards    Board[]
  memberships Membership[]

  @@index([spaceId])
  @@map("departments")
}

model Membership {
  id           String    @id @default(cuid())
  userId       String
  spaceId      String?   // set when member of a Space
  departmentId String?   // set when member of a Department
  roleId       String
  invitedAt    DateTime  @default(now())
  acceptedAt   DateTime?

  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  role         Role      @relation(fields: [roleId], references: [id])
  space        Space?    @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  department   Department? @relation(fields: [departmentId], references: [id], onDelete: Cascade)

  @@unique([userId, spaceId])
  @@unique([userId, departmentId])
  @@index([userId])
  @@index([spaceId])
  @@index([departmentId])
  @@index([roleId])
  @@map("memberships")
}

model SubscriptionPlan {
  id          String   @id @default(cuid())
  name        String   @unique // "FREE" | "PRO" | "ENTERPRISE"
  maxSpaces   Int
  maxUsers    Int
  maxBoards   Int
  aiEnabled   Boolean  @default(false)
  price       Float

  spaces      Space[]

  @@map("subscription_plans")
}

model SpaceCounter {
  spaceId String @id
  seq     Int    @default(0)

  space   Space  @relation(fields: [spaceId], references: [id], onDelete: Cascade)

  @@map("space_counters")
}

model Invitation {
  id        String   @id @default(cuid())
  email     String
  spaceId   String
  role      String   @default("MEMBER")
  token     String   @unique @default(cuid())
  expiresAt DateTime
  accepted  Boolean  @default(false)
  createdAt DateTime @default(now())

  space     Space    @relation(fields: [spaceId], references: [id], onDelete: Cascade)

  @@index([email, spaceId])
  @@index([token])
  @@map("invitations")
}

model Subscription {
  id           String           @id @default(cuid())
  userId       String
  tier         SubscriptionTier @default(FREE)
  startsAt     DateTime         @default(now())
  expiresAt    DateTime?
  isAutoRenew  Boolean          @default(false)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tier])
  @@map("subscriptions")
}

// Usage metering — feeds billing dashboard & quota enforcement
model UsageRecord {
  id          String   @id @default(cuid())
  spaceId     String
  metric      String   // 'AI_REQUESTS' | 'AI_TOKENS' | 'STORAGE_MB' | 'MEMBERS'
  value       Int
  recordedAt  DateTime @default(now())

  @@index([spaceId, metric, recordedAt])
  @@map("usage_records")
}

// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// BOARDS
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

model Board {
  id           String      @id @default(cuid())
  name         String
  description  String?
  departmentId String
  type         BoardType   @default(KANBAN)
  position     Int         @default(0)
  color        String?
  icon         String?
  isArchived   Boolean     @default(false)
  deletedAt    DateTime?
  deletedById  String?
  restoreToken String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  department   Department  @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  columns      BoardColumn[]
  tasks        Task[]
  views        View[]

  @@index([departmentId])
  @@index([isArchived])
  @@index([createdAt])
  @@map("boards")
}

model BoardColumn {
  id        String   @id @default(cuid())
  boardId   String
  name      String
  position  Int
  color     String?
  wipLimit  Int?
  deletedAt    DateTime?
  deletedById  String?
  restoreToken String?

  board     Board    @relation(fields: [boardId], references: [id], onDelete: Cascade)
  tasks     Task[]

  @@index([boardId])
  @@map("board_columns")
}

model View {
  id          String    @id @default(cuid())
  boardId     String
  name        String
  type        BoardType
  filters     Json?     // serialized filter config
  groupBy     String?
  sortBy      String?
  sortOrder   String?   // "asc" | "desc"
  isDefault   Boolean   @default(false)
  createdById String
  createdAt   DateTime  @default(now())

  board       Board     @relation(fields: [boardId], references: [id], onDelete: Cascade)

  @@index([boardId])
  @@index([createdById])
  @@map("views")
}

// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// TASKS
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

model Task {
  id              String       @id @default(cuid())
  identifier      String       @unique // "EDU-042" auto-generated
  title           String
  description     String?      // rich markdown
  boardId         String
  columnId        String?
  status          TaskStatus   @default(TODO)
  priority        Priority     @default(MEDIUM)
  type            String?      // "Task" | "Bug" | "Feature" | "Milestone"
  position        Int          @default(0)
  estimatedHours  Float?
  percentDone     Int          @default(0)
  dueDate         DateTime?
  startDate       DateTime?
  parentId        String?      // for subtasks (self-relation)
  tags            String[]
  searchVector    Unsupported("tsvector")?
  isArchived      Boolean      @default(false)
  deletedAt    DateTime?
  deletedById  String?
  restoreToken String?
  createdById     String
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  board           Board        @relation(fields: [boardId], references: [id], onDelete: Cascade)
  column          BoardColumn? @relation(fields: [columnId], references: [id], onDelete: SetNull)
  parent          Task?        @relation("Subtasks", fields: [parentId], references: [id], onDelete: SetNull)
  subtasks        Task[]       @relation("Subtasks")
  assignments     TaskAssignment[]
  dependencies    TaskDependency[] @relation("DependencyOf")
  dependents      TaskDependency[] @relation("DependentOn")
  comments        Comment[]
  attachments     Attachment[]
  approvals       Approval[]
  timeLogs        TimeLog[]
  watchers        Watcher[]
  journalEntries  TaskJournal[]
  activities      Activity[]
  driveAttachments DriveAttachment[]

  @@index([boardId])
  @@index([columnId])
  @@index([parentId])
  @@index([status])
  @@index([priority])
  @@index([dueDate])
  @@index([isArchived])
  @@index([searchVector], type: Gin)
  @@index([identifier])
  @@index([createdById])
  @@index([createdAt])
  @@map("tasks")
}

model TaskAssignment {
  taskId     String
  userId     String
  assignedAt DateTime @default(now())

  task       Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([taskId, userId])
  @@index([userId])
  @@map("task_assignments")
}

model TaskDependency {
  id             String         @id @default(cuid())
  taskId         String         // the dependent task
  dependsOnId    String         // the prerequisite task
  type           DependencyType @default(BLOCKS)

  task           Task           @relation("DependencyOf", fields: [taskId], references: [id], onDelete: Cascade)
  dependsOn      Task           @relation("DependentOn", fields: [dependsOnId], references: [id], onDelete: Cascade)

  @@unique([taskId, dependsOnId])
  @@index([dependsOnId])
  @@map("task_dependencies")
}

model TimeLog {
  id        String   @id @default(cuid())
  taskId    String
  userId    String
  hours     Float
  loggedAt  DateTime @default(now())
  note      String?

  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([userId])
  @@index([loggedAt])
  @@map("time_logs")
}

model Watcher {
  taskId String
  userId String

  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([taskId, userId])
  @@map("watchers")
}

// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// COLLABORATION
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

model Comment {
  id        String    @id @default(cuid())
  taskId    String
  authorId  String
  content   String    // markdown with @mention support
  isEdited  Boolean   @default(false)
  deletedAt DateTime?              // soft delete
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  task      Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  author    User      @relation("CommentAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  mentions  Mention[]
  reactions EmojiReaction[]

  @@index([taskId])
  @@index([authorId])
  @@index([createdAt])
  @@map("comments")
}

model Mention {
  commentId   String
  mentionedId String // userId
  isRead      Boolean  @default(false)

  comment     Comment  @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@id([commentId, mentionedId])
  @@index([mentionedId])
  @@index([isRead])
  @@map("mentions")
}

model EmojiReaction {
  id        String   @id @default(cuid())
  commentId String
  userId    String
  emoji     String

  comment   Comment  @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@unique([commentId, userId, emoji])
  @@index([commentId])
  @@map("emoji_reactions")
}

// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// FILES & VERSIONS
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

model Attachment {
  id               String       @id @default(cuid())
  taskId           String
  spaceId          String
  fileName         String
  mimeType         String
  currentVersionId String?
  uploadedById     String
  createdAt        DateTime     @default(now())

  task             Task         @relation(fields: [taskId], references: [id], onDelete: Cascade)
  space            Space        @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  versions         FileVersion[]

  @@index([taskId])
  @@index([spaceId])
  @@map("attachments")
}

model FileVersion {
  id               String             @id @default(cuid())
  attachmentId     String
  storageKey       String
  versionNum       Int
  fileSize         BigInt
  checksum         String?
  provider         AttachmentProvider @default(LOCAL)
  externalUrl      String?
  embeddingStatus  EmbeddingStatus    @default(PENDING)
  uploadedById     String
  uploadedAt       DateTime           @default(now())

  attachment       Attachment         @relation(fields: [attachmentId], references: [id], onDelete: Cascade)
  uploader         User               @relation(fields: [uploadedById], references: [id], onDelete: Cascade)

  @@index([attachmentId])
  @@index([uploadedById])
  @@map("file_versions")
}

// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// APPROVALS & WORKFLOWS
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

model Approval {
  id            String         @id @default(cuid())
  taskId        String
  requestedById String
  reviewerId    String?
  status        ApprovalStatus @default(PENDING)
  comment       String?
  requestedAt   DateTime       @default(now())
  resolvedAt    DateTime?

  task          Task           @relation(fields: [taskId], references: [id], onDelete: Cascade)
  requester     User           @relation("ApprovalRequester", fields: [requestedById], references: [id])
  reviewer      User?          @relation("ApprovalReviewer", fields: [reviewerId], references: [id])

  @@index([taskId])
  @@index([requestedById])
  @@index([reviewerId])
  @@index([status])
  @@index([requestedAt])
  @@map("approvals")
}

// Generic Workflow Engine — handles all approval types
// (task approval, budget, AI actions, leave requests, etc.)

model WorkflowDefinition {
  id          String   @id @default(cuid())
  spaceId     String
  name        String
  triggerType String   // 'MANUAL' | 'AI_PROPOSED' | 'SCHEDULED'
  isActive    Boolean  @default(true)
  createdBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  steps       WorkflowStep[]
  instances   WorkflowInstance[]

  @@index([spaceId])
  @@index([isActive])
  @@map("workflow_definitions")
}

model WorkflowStep {
  id            String   @id @default(cuid())
  definitionId  String
  order         Int
  name          String
  approverType  String   // 'USER' | 'ROLE' | 'MANAGER_OF_REQUESTER'
  approverIds   String[]
  approverRole  String?
  isParallel    Boolean  @default(false)
  requiresAll   Boolean  @default(true)
  timeoutHours  Int?

  definition    WorkflowDefinition @relation(fields: [definitionId], references: [id], onDelete: Cascade)

  @@index([definitionId])
  @@map("workflow_steps")
}

model WorkflowInstance {
  id            String   @id @default(cuid())
  definitionId  String
  spaceId       String
  entityType    String   // 'TASK' | 'AI_ACTION' | 'BUDGET' | 'CUSTOM'
  entityId      String
  requesterId   String
  currentStep   Int      @default(0)
  status        String   @default("PENDING") // 'PENDING' | 'IN_PROGRESS' | 'APPROVED' | 'REJECTED' | 'CANCELLED' | 'TIMED_OUT'
  context       Json?
  deletedAt     DateTime?
  deletedById   String?
  restoreToken  String?
  createdAt     DateTime @default(now())
  resolvedAt    DateTime?

  definition    WorkflowDefinition @relation(fields: [definitionId], references: [id])
  requester     User             @relation("WorkflowRequester", fields: [requesterId], references: [id])
  actions       WorkflowAction[]

  @@index([definitionId])
  @@index([spaceId])
  @@index([entityType, entityId])
  @@index([requesterId])
  @@index([status])
  @@index([createdAt])
  @@map("workflow_instances")
}

model WorkflowAction {
  id          String   @id @default(cuid())
  instanceId  String
  stepOrder   Int
  actorId     String
  decision    String   // 'APPROVED' | 'REJECTED' | 'DELEGATED'
  note        String?
  createdAt   DateTime @default(now())

  instance    WorkflowInstance @relation(fields: [instanceId], references: [id], onDelete: Cascade)

  @@index([instanceId])
  @@index([actorId])
  @@map("workflow_actions")
}

// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// NOTIFICATIONS & AUDIT
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

model OutboxEvent {
  id            String   @id @default(cuid())
  aggregateType String   
  aggregateId   String
  eventType     String   
  payload       Json     
  processedAt   DateTime?
  createdAt     DateTime @default(now())

  @@index([processedAt, createdAt])
  @@map("outbox_events")
}

model Notification {
  id                String    @id @default(cuid())
  userId            String
  spaceId           String    
  type              String    
  priority          NotificationPriority  @default(NORMAL)
  channel           NotificationChannelType
  title             String
  body              String
  entityType        String?   
  entityId          String?
  status            NotificationStatus @default(PENDING)
  aggregatedGroupId String?   
  deliveredAt       DateTime?
  readAt            DateTime?
  failedAt          DateTime?
  metadata          Json?     
  templateVersion   Int       @default(1)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, spaceId, status])
  @@index([aggregatedGroupId])
  @@map("notifications")
}

model NotificationPreference {
  id           String   @id @default(cuid())
  userId       String   @unique
  preferences  Json     
  quietHours   Json?    
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notification_preferences")
}

model DeviceSession {
  id           String   @id @default(cuid())
  userId       String
  deviceType   String   
  pushToken    String?  
  lastSeen     DateTime @default(now())
  revokedAt    DateTime?
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, revokedAt])
  @@map("device_sessions")
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String
  action     String   // "task.created" | "task.status_changed" | "member.invited" ...
  entityType String
  entityId   String
  diff       Json?    // before/after JSON
  ipAddress  String?
  timestamp  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([action])
  @@index([entityType, entityId])
  @@index([timestamp])
  @@map("audit_logs")
}

model TaskJournal {
  id        String   @id @default(cuid())
  taskId    String
  userId    String
  changes   Json     // { field: "status", from: "TODO", to: "IN_PROGRESS" }
  note      String?
  createdAt DateTime @default(now())

  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([userId])
  @@index([createdAt])
  @@map("task_journal")
}

// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// ACTIVITY LOG
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

model Activity {
  id        String   @id @default(cuid())
  userId    String
  taskId    String?
  type      String
  data      Json?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  task      Task?    @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([taskId])
  @@index([type])
  @@index([createdAt])
  @@map("activities")
}

// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// AI SYSTEM
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

model AIRequest {
  id              String   @id @default(cuid())
  traceId         String   @unique
  userId          String
  spaceId         String
  intent          String                  // 'risk' | 'chat' | 'report' | 'action'
  rawInput        String
  rewrittenQuery  String?
  finalResponse   String?
  modelUsed       String?                 // 'llama-3.3-70b' | 'gemma2-9b' etc. (via Groq)
  tokensIn        Int?
  tokensOut       Int?
  latencyMs       Int?
  ttftMs          Int?
  qualityScore    Float?
  userFeedback    Int?                    // 1 = thumbs up, -1 = thumbs down
  feedbackNote    String?
  status          String   @default("pending") // pending | completed | failed
  errorMessage    String?
  createdAt       DateTime @default(now())

  user            User     @relation(fields: [userId], references: [id])
  proposedActions AIProposedAction[]

  @@index([userId])
  @@index([spaceId])
  @@index([intent])
  @@index([traceId])
  @@index([createdAt])
  @@map("ai_requests")
}

model AIProposedAction {
  id              String         @id @default(cuid())
  traceId         String
  spaceId         String
  commandType     String         // 'AssignTask' | 'CreateTask' | 'EscalateTask' | 'UpdateTask' | 'CreateReminder'
  payload         Json
  reason          String
  status          ApprovalStatus @default(PENDING)
  reviewedById    String?
  reviewedAt      DateTime?
  executedAt      DateTime?
  executedBy      String?
  executionStatus String?        @default("PENDING") // 'PENDING' | 'SUCCESS' | 'FAILED'
  createdAt       DateTime       @default(now())

  aiRequest       AIRequest      @relation(fields: [traceId], references: [traceId])
  reviewer        User?          @relation("AIActionReviewer", fields: [reviewedById], references: [id])
  executor        User?          @relation("AIActionExecutor", fields: [executedBy], references: [id])

  @@index([traceId])
  @@index([spaceId])
  @@index([status])
  @@map("ai_proposed_actions")
}

model AIConversationTurn {
  id        String   @id @default(cuid())
  userId    String
  spaceId   String
  role      String   // 'user' | 'assistant'
  content   String
  traceId   String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, spaceId, createdAt])
  @@map("ai_conversation_turns")
}

model AIEvalResult {
  id              String   @id @default(cuid())
  traceId         String?
  evalType        String   // 'shadow' | 'ci' | 'manual'
  feature         String   // 'risk_detection' | 'chat' | 'report'
  metricName      String   // 'f1' | 'rubric_score' | 'faithfulness'
  metricValue     Float
  details         Json?
  promptVersion   String?
  modelUsed       String?
  createdAt       DateTime @default(now())

  @@index([feature])
  @@index([metricName])
  @@index([createdAt])
  @@map("ai_eval_results")
}

model FeatureFlag {
  id             String   @id @default(cuid())
  key            String   @unique
  description    String
  isEnabled      Boolean  @default(false)
  enabledFor     String[] // User IDs or Space IDs
  rolloutPercent Int      @default(0) // 0-100
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("feature_flags")
}

model UserPreference {
  id         String   @id @default(cuid())
  userId     String   @unique
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  language   String   @default("en")
  timezone   String   @default("UTC")
  theme      String   @default("system") // 'light' | 'dark' | 'system'
  dateFormat String   @default("DD/MM/YYYY")
  weekStart  String   @default("MON")
  updatedAt  DateTime @updatedAt

  @@map("user_preferences")
}

model Integration {
  id           String   @id @default(cuid())
  userId       String
  provider     String   // "google_drive"
  accessToken  String   // stored encrypted (AES-256)
  refreshToken String   // stored encrypted
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
  @@map("integrations")
}

model DriveAttachment {
  id          String    @id @default(cuid())
  taskId      String
  driveFileId String
  driveLink   String
  fileName    String
  mimeType    String
  size        BigInt?
  version     Int       @default(1)
  watchExpiry DateTime? // Google Drive push notification expiry
  channelId   String?   // Drive webhook channel ID
  createdAt   DateTime  @default(now())
  task        Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([driveFileId])
  @@map("drive_attachments")
}

model AIMemoryProfile {
  id           String   @id @default(cuid())
  userId       String   @unique
  preferences  Json     // stores extracted facts/preferences
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("ai_memory_profiles")
}

// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// WHATSAPP (Meta Cloud API)
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

model WhatsAppAccount {
  id              String   @id @default(cuid())
  spaceId         String   @unique
  phoneNumberId   String   // Meta phone number ID
  wabaId          String   // WhatsApp Business Account ID
  accessToken     String   // Encrypted (system user permanent token)
  displayName     String
  isActive        Boolean  @default(true)
  webhookSecret   String?  // App secret used for payload signature verification
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("whatsapp_accounts")
}

model WhatsAppContact {
  id          String   @id @default(cuid())
  userId      String   // Mongez user
  spaceId     String
  phoneNumber String   // E.164 format (+966...)
  waId        String?  // WhatsApp ID
  isVerified  Boolean  @default(false)
  optedIn     Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, spaceId])
  @@index([phoneNumber])
  @@map("whatsapp_contacts")
}

model WhatsAppMessage {
  id            String   @id @default(cuid())
  spaceId       String
  direction     String   // 'OUTBOUND' | 'INBOUND'
  waMessageId   String?  @unique // Meta's message ID
  fromPhone     String
  toPhone       String
  templateName  String?  // For outbound template messages
  content       String   // Message body
  mediaUrl      String?
  status        String   @default("PENDING") // PENDING | SENT | DELIVERED | READ | FAILED
  errorCode     String?
  metadata      Json?
  createdAt     DateTime @default(now())

  @@index([spaceId, createdAt])
  @@index([waMessageId])
  @@map("whatsapp_messages")
}

// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// TELEGRAM (Bot API)
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

model TelegramAccount {
  id              String   @id @default(cuid())
  spaceId         String   @unique
  botToken        String   // Encrypted space bot token
  botUsername     String
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("telegram_accounts")
}

model TelegramContact {
  id          String   @id @default(cuid())
  userId      String
  spaceId     String
  chatId      String   // Telegram chat ID (unique per bot/user pair)
  username    String?
  isVerified  Boolean  @default(false)
  optedIn     Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, spaceId])
  @@unique([chatId, spaceId])
  @@map("telegram_contacts")
}

model TelegramMessage {
  id            String   @id @default(cuid())
  spaceId       String
  direction     String   // 'OUTBOUND' | 'INBOUND'
  tgMessageId   Int?     // Telegram message ID
  chatId        String
  content       String   // Message body
  status        String   @default("PENDING") // PENDING | SENT | FAILED
  errorCode     String?
  metadata      Json?
  createdAt     DateTime @default(now())

  @@index([spaceId, createdAt])
  @@map("telegram_messages")
}
